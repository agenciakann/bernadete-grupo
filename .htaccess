# ============================================================
# URLs limpas (sem .html) — Host Apache (mod_rewrite)
# ============================================================

RewriteEngine On

# ------------------------------------------------------------
# Protecao: o repositorio git fica dentro da pasta publica,
# entao bloqueamos o acesso a arquivos internos pela web.
# ------------------------------------------------------------
# Pasta .git e .gitignore (codigo-fonte / historico)
RewriteRule (^|/)\.git - [F,L]
# Configs e documentacao do projeto (.cpanel.yml, .prd, .spec, .md, .gs)
RewriteRule \.(yml|prd|spec|md|gs)$ - [F,L]
# Pasta do Google Apps Script
RewriteRule ^google-apps-script(/|$) - [F,L]

# 1) /index e /index.html  ->  raiz "/"
RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
RewriteRule ^ / [R=301,L]

# 2) Redireciona a URL antiga com .html para a versao limpa (301, bom p/ SEO)
#    Ex.: /obrigado.html  ->  /obrigado
RewriteCond %{THE_REQUEST} \s/+([^?\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 3) Serve internamente o arquivo .html correspondente a URL limpa
#    Ex.: barra mostra /obrigado, servidor entrega obrigado.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
